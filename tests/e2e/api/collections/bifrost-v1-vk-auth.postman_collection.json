            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"{{provider}}/{{embedding_model}}\",\n  \"input\": \"Hello world\",\n  \"encoding_format\": \"float\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/embeddings",
              "host": [
                "{{base_url}}"
