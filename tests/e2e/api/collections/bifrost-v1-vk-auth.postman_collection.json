            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"{{provider}}/{{responses_model}}\",\n  \"input\": \"Say hello\",\n  \"max_output_tokens\": 50\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/responses",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "responses"
              ]
            }
          }
        }
