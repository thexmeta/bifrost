        "provider_configs": [
          {
            "provider": "nvidia-nim",
            "weight": 1.0,
            "allowed_models": ["qwen/qwen3-coder-480b-a35b-instruct"]
          },
          {
            "provider": "nvidia-nim",
            "weight": 0.0,
