          }
        ]
      },
      {
        "id": "vk-gemini-researcher",
        "name": "Gemini Grounded Research",
        "provider_configs": [
          {
            "provider": "google",
            "allowed_models": [
              "gemini-3.1-flash-lite-preview",
              "gemini-3-flash-preview"
            ]
          }
        ]
      }
    ]
  },
  "plugins": [
    {
      "enabled": true,
      "name": "semantic_cache",
      "config": {
        "provider": "nvidia-nim",
        "keys": ["env.NVIDIA_NIM_API_KEY"],
        "embedding_model": "nvidia/nv-embed-v1",
        "dimension": 1024,
        "cleanup_on_shutdown": true,
        "ttl": "10m",
        "threshold": 0.82,
        "conversation_history_threshold": 2,
        "cache_by_model": true,
        "cache_by_provider": true,
        "exclude_system_prompt": false
      }
    }
  ],
  "vector_store": {
    "enabled": true,
    "type": "qdrant",
    "config": {
      "host": "localhost",
      "port": 6334,
      "api_key": "env.YOUR_API_KEY_HERE"
    }
  },
  "providers": {
    "nvidia-nim": {
      "keys": [
        {
          "name": "nim",
          "value": "env.NVIDIA_NIM_API_KEY",
          "models": [
            "z-ai/glm4.7",
            "qwen/qwen3-coder-480b-a35b-instruct",
            "qwen/qwen3.5-122b-a10b",
            "nvidia/nv-embed-v1",
            "nvidia/nv-embedcode-7b-v1",
            "google/gemma-3-27b-it",
            "google/gemma-4-31b-it",
            "deepseek-ai/deepseek-v3.2",
            "deepseek-ai/deepseek-v3.1-terminus"
          ],
          "weight": 1.0
        },
        {
          "name": "nim-glm5-key",
          "value": "env.NIM_GLM_API_KEY",
          "models": ["z-ai/glm5"],
          "weight": 1.0
        },
        {
          "name": "nim-minimax-key",
          "value": "env.NIM_MINIMAX_API_KEY",
          "models": ["minimaxai/minimax-m2.5"],
          "weight": 1.0
        },
        {
          "name": "nim-kimi-k2i-key",
          "value": "env.NIM_KIMIK2I_API_KEY",
          "models": ["moonshotai/kimi-k2-instruct"],
          "weight": 1.0
        },
        {
